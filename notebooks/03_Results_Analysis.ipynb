    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('Learning Rate (log scale)')\n",
    "ax.legend(fontsize=8)\n",
    "# Annotate phase LR values\n",
    "ax.annotate('LR = 1e-3', xy=(5, 7e-4), fontsize=8, color='#3498db', fontweight='bold')\n",
