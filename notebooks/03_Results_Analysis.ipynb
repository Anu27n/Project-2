    "fig = plt.figure(figsize=(20, 14))\n",
    "gs  = gridspec.GridSpec(3, 3, figure=fig, hspace=0.42, wspace=0.32)\n",
    "fig.suptitle(\n",
    "    'EfficientNet-B4 Training Curves — APTOS 2019 Diabetic Retinopathy Detection',\n",
    "    fontsize=14, fontweight='bold', y=1.01\n",
    ")\n",
    "\n",
    "phase_colors = {'Phase 1': '#3498db', 'Phase 2': '#e67e22', 'Phase 3': '#2ecc71'}\n",
    "phase_boundaries = [10, 25]   # epoch numbers where phases switch\n",
    "\n",
    "def add_phase_bands(ax, alpha=0.07):\n",
    "    \"\"\"Shade phase backgrounds on an axis.\"\"\"\n",
    "    ax.axvspan(1,  10, alpha=alpha, color='#3498db', label='Phase 1')\n",
    "    ax.axvspan(10, 25, alpha=alpha, color='#e67e22', label='Phase 2')\n",
    "    ax.axvspan(25, 30, alpha=alpha, color='#2ecc71', label='Phase 3')\n",
    "    for e in phase_boundaries:\n",
    "        ax.axvline(x=e, color='gray', linestyle=':', linewidth=1.2, alpha=0.6)\n",
    "\n",
    "# ── (0,0): Loss ───────────────────────────────────────────────\n",
    "ax = fig.add_subplot(gs[0, 0])\n",
    "add_phase_bands(ax)\n",
    "ax.plot(epochs, train_loss, 'b-o', ms=3, lw=2, label='Train Loss',  alpha=0.85)\n",
    "ax.plot(epochs, val_loss,   'r-s', ms=3, lw=2, label='Val Loss',    alpha=0.85)\n",
    "ax.plot(epochs, smooth(train_loss), 'b--', lw=1.5, alpha=0.5)\n",
    "ax.plot(epochs, smooth(val_loss),   'r--', lw=1.5, alpha=0.5)\n",
    "ax.set_title('Loss (Weighted Focal + Label Smooth CE)', fontweight='bold')\n",
    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('Loss')\n",
    "ax.legend(loc='upper right', fontsize=8)\n",
    "ax.set_xlim(1, 30)\n",
    "\n",
    "# ── (0,1): Accuracy ───────────────────────────────────────────\n",
    "ax = fig.add_subplot(gs[0, 1])\n",
    "add_phase_bands(ax)\n",
    "ax.plot(epochs, train_acc * 100, 'b-o', ms=3, lw=2, label='Train Acc', alpha=0.85)\n",
    "ax.plot(epochs, val_acc   * 100, 'r-s', ms=3, lw=2, label='Val Acc',   alpha=0.85)\n",
    "ax.axhline(y=90, color='green', linestyle='--', lw=1.5, alpha=0.7, label='Target 90%')\n",
    "ax.set_title('Classification Accuracy (%)', fontweight='bold')\n",
    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('Accuracy (%)')\n",
    "ax.set_ylim(40, 100)\n",
    "ax.legend(loc='lower right', fontsize=8)\n",
    "ax.set_xlim(1, 30)\n",
    "\n",
    "# ── (0,2): QWK ────────────────────────────────────────────────\n",
    "ax = fig.add_subplot(gs[0, 2])\n",
    "add_phase_bands(ax)\n",
    "ax.plot(epochs, train_qwk, 'b-o', ms=3, lw=2, label='Train QWK', alpha=0.85)\n",
    "ax.plot(epochs, val_qwk,   'r-s', ms=3, lw=2, label='Val QWK',   alpha=0.85)\n",
    "ax.axhline(y=0.85, color='green', linestyle='--', lw=1.5, alpha=0.7, label='Target 0.85')\n",
    "best_epoch = history_df['val_qwk'].idxmax() + 1\n",
    "best_val   = history_df['val_qwk'].max()\n",
    "ax.scatter([best_epoch], [best_val], s=120, color='gold', zorder=5,\n",
    "           edgecolors='black', linewidth=1.5, label=f'Best: {best_val:.4f}')\n",
    "ax.set_title('Quadratic Weighted Kappa (QWK)', fontweight='bold')\n",
    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('QWK Score')\n",
    "ax.set_ylim(0.2, 1.0)\n",
    "ax.legend(loc='lower right', fontsize=8)\n",
    "ax.set_xlim(1, 30)\n",
    "\n",
    "# ── (1,0): AUC-ROC ────────────────────────────────────────────\n",
    "ax = fig.add_subplot(gs[1, 0])\n",
    "add_phase_bands(ax)\n",
    "ax.plot(epochs, val_auc, 'm-D', ms=3, lw=2, label='Val AUC-ROC', alpha=0.85)\n",
    "ax.plot(epochs, smooth(val_auc), 'm--', lw=1.5, alpha=0.5)\n",
    "ax.axhline(y=0.95, color='green', linestyle='--', lw=1.5, alpha=0.7, label='Target 0.95')\n",
    "ax.set_title('AUC-ROC (Macro, One-vs-Rest)', fontweight='bold')\n",
    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('AUC-ROC')\n",
    "ax.set_ylim(0.75, 1.0)\n",
    "ax.legend(loc='lower right', fontsize=8)\n",
    "ax.set_xlim(1, 30)\n",
    "\n",
    "# ── (1,1): Learning Rate ──────────────────────────────────────\n",
    "ax = fig.add_subplot(gs[1, 1])\n",
