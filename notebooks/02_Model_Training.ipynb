    "    'format'         : 'PNG',\n",
    "}\n",
    "\n",
    "# Build a representative DataFrame\n",
    "rows = []\n",
    "for cls_idx, (name, count) in enumerate(zip(DATASET_STATS['class_names'],\n",
    "                                             DATASET_STATS['class_counts'])):\n",
    "    rows.append({'Class': cls_idx, 'Name': name, 'Count': count,\n",
    "                 'Percentage': count / DATASET_STATS['total_images'] * 100})\n",
    "\n",
    "df_stats = pd.DataFrame(rows)\n",
    "df_stats['Inv_Freq_Weight'] = (\n",
    "    DATASET_STATS['total_images'] /\n",
    "    (CONFIG['num_classes'] * df_stats['Count'])\n",
    ")\n",
    "df_stats['Inv_Freq_Weight'] /= df_stats['Inv_Freq_Weight'].mean()  # normalize\n",
    "\n",
    "print('=' * 60)\n",
    "print('  APTOS 2019 — CLASS DISTRIBUTION')\n",
    "print('=' * 60)\n",
    "print(df_stats.to_string(index=False, float_format='{:.3f}'.format))\n",
