    "# ─── APTOS 2019 dataset statistics ───────────────────────────\n",
    "# (Full dataset — 3,662 images)\n",
    "DATASET_STATS = {\n",
    "    'total_images'   : 3662,\n",
    "    'class_counts'   : [1805, 370, 999, 193, 295],\n",
    "    'class_names'    : CONFIG['class_names'],\n",
    "    'train_size'     : 2929,   # 80%\n",
    "    'val_size'       : 366,    # 10%\n",
